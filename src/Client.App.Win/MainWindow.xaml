<Window x:Class="Client.App.Win.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loki Proxy"
        Width="500"
        Height="825"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/Icons/app.ico"
        AllowsTransparency="True"
        Background="Transparent"
        Opacity="0"
        ContextMenu="{x:Null}"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <FontFamily x:Key="PixelFont">Bitcount Prop Double, Bitcount Prop Double Open Default, Bitcount Prop Double Open Defau, ./Assets/Fonts/#Bitcount Prop Double, ./Assets/Fonts/#Bitcount Prop Double Open Default, ./Assets/Fonts/#Bitcount Prop Double Open Defau, pack://application:,,,/Assets/Fonts/#Bitcount Prop Double, pack://application:,,,/Assets/Fonts/#Bitcount Prop Double Open Default, pack://application:,,,/Assets/Fonts/#Bitcount Prop Double Open Defau</FontFamily>
        <FontFamily x:Key="DecorFont">Sekuya, ./Assets/Fonts/#Sekuya, pack://application:,,,/Assets/Fonts/#Sekuya</FontFamily>
        <FontFamily x:Key="ScriptFont">Bad Script, ./Assets/Fonts/#Bad Script, pack://application:,,,/Assets/Fonts/#Bad Script</FontFamily>

        <SolidColorBrush x:Key="BlackBrush" Color="#000000" />
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="GreenBrush" Color="#57C086" />
        <SolidColorBrush x:Key="RedBrush" Color="#EA2F2F" />

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource PixelFont}" />
        </Style>

        <Style x:Key="PixelTextButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource PixelFont}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ContextMenu" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#777777" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkPixelButton" TargetType="Button" BasedOn="{StaticResource PixelTextButton}">
            <Setter Property="Foreground" Value="{StaticResource BlackBrush}" />
        </Style>

        <Style x:Key="ScaleTextButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource PixelFont}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ContextMenu" Value="{x:Null}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.045" Duration="0:0:0.11" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.045" Duration="0:0:0.11" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.11" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.11" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MainNavSegmentButton" TargetType="Button">
            <Setter Property="Background" Value="#000000" />
            <Setter Property="BorderBrush" Value="{StaticResource WhiteBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource PixelFont}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ContextMenu" Value="{x:Null}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Panel.ZIndex" Value="2" />
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.035" Duration="0:0:0.11" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.035" Duration="0:0:0.11" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.11" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.11" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MainNavSegmentText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MainCenterButton" TargetType="Button" BasedOn="{StaticResource PixelTextButton}">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Width" Value="240" />
            <Setter Property="Height" Value="58" />
            <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
            <Setter Property="Foreground" Value="{StaticResource BlackBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="{StaticResource PixelFont}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ContextMenu" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="29">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource GreenBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AddConnectionPillButton" TargetType="Button">
            <Setter Property="Width" Value="240" />
            <Setter Property="Height" Value="45" />
            <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
            <Setter Property="Foreground" Value="{StaticResource BlackBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="{StaticResource PixelFont}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ContextMenu" Value="{x:Null}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="PillRoot" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Grid.RenderTransform>
                            <Border x:Name="PillSurface" Background="{TemplateBinding Background}" CornerRadius="22.5" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PillRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.045" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="PillRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.045" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PillRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="PillRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoutingField" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="#000000" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#57C086" />
            <Setter Property="CaretBrush" Value="#57C086" />
            <Setter Property="FontFamily" Value="{StaticResource PixelFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="ContextMenu" Value="{x:Null}" />
        </Style>
    </Window.Resources>

    <Grid x:Name="WindowFrame" Width="500" Height="825" Background="#000000" ClipToBounds="True" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="WindowScale" ScaleX="0.98" ScaleY="0.98" />
                <TranslateTransform x:Name="WindowTranslate" X="0" Y="0" />
            </TransformGroup>
        </Grid.RenderTransform>
        <Grid.Clip>
            <RectangleGeometry Rect="0,0,500,825" RadiusX="10" RadiusY="10" />
        </Grid.Clip>
        <Grid.RowDefinitions>
            <RowDefinition Height="25" />
            <RowDefinition Height="800" />
        </Grid.RowDefinitions>

        <Grid x:Name="TopBar" Grid.Row="0" Background="#000000" MouseLeftButtonDown="Window_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                <Button Width="28" Height="20" Margin="0,0,8,0" Style="{StaticResource PixelTextButton}" Click="Minimize_Click">
                    <TextBlock x:Name="TopMinimizeText" Text="_" FontSize="18" Foreground="{StaticResource WhiteBrush}" />
                </Button>
                <Button Width="28" Height="20" Style="{StaticResource PixelTextButton}" Click="Close_Click">
                    <TextBlock x:Name="TopCloseText" Text="x" FontSize="18" Foreground="{StaticResource WhiteBrush}" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid x:Name="Root" Grid.Row="1" Width="500" Height="800" ClipToBounds="True" Background="#000000">
        <Grid x:Name="EntryScreen" Background="{StaticResource GreenBrush}" Visibility="Collapsed">
            <Canvas Width="500" Height="800">
                <TextBlock Canvas.Left="0" Canvas.Top="80" Width="500" Text="LOKI" TextAlignment="Center" FontFamily="{StaticResource DecorFont}" FontSize="80" Foreground="#FFFFFF" />
                <TextBlock Canvas.Left="0" Canvas.Top="185" Width="500" Text="PROXY" TextAlignment="Center" FontFamily="{StaticResource DecorFont}" FontSize="80" Foreground="#FFFFFF" />
                <StackPanel Canvas.Left="0" Canvas.Top="343" Width="500">
                    <TextBlock Text="entering qr code" TextAlignment="Center"
                               FontFamily="{StaticResource PixelFont}" FontSize="24" Foreground="#FFFFFF" />
                    <Image Source="Assets/Onboarding/invite-qr.png" Width="166" Height="166" Stretch="Uniform" Margin="0,24,0,0"
                           HorizontalAlignment="Center" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                </StackPanel>
                <Button Canvas.Left="68" Canvas.Top="660" Width="365" Height="54" Style="{StaticResource ScaleTextButton}" Click="EntrySkip_Click">
                    <TextBlock Text="I already have connection&#x0a;link -&gt; skip" TextAlignment="Center" FontSize="24" />
                </Button>
            </Canvas>
        </Grid>

        <Grid x:Name="GuideScreen" Background="#000000" Visibility="Collapsed">
            <Image Source="Assets/Onboarding/entry-guide.png" Width="500" Height="800" Stretch="Uniform" />
            <Border Visibility="Collapsed" Margin="34,32,34,78" BorderBrush="#FFFFFF" BorderThickness="2">
                <Canvas>
                    <TextBlock Canvas.Left="264" Canvas.Top="150" Text="turn on and turn off" FontFamily="{StaticResource ScriptFont}" FontSize="22" Foreground="{StaticResource GreenBrush}" />
                    <TextBlock Canvas.Left="320" Canvas.Top="190" Text="by this button" FontFamily="{StaticResource ScriptFont}" FontSize="22" Foreground="{StaticResource GreenBrush}" />
                    <TextBlock Canvas.Left="250" Canvas.Top="197" Text="↙" FontFamily="Segoe UI Symbol" FontSize="94" Foreground="{StaticResource GreenBrush}" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="-22" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <StackPanel Canvas.Left="180" Canvas.Top="305" Width="140">
                        <TextBlock Text="OFF" FontFamily="{StaticResource PixelFont}" FontSize="48" Foreground="#FFFFFF" HorizontalAlignment="Center" />
                        <TextBlock Text="Hey!" FontFamily="{StaticResource PixelFont}" FontSize="18" Foreground="#FFFFFF" />
                        <TextBlock Text="Push on me!" FontFamily="{StaticResource PixelFont}" FontSize="18" Foreground="#FFFFFF" />
                    </StackPanel>
                    <TextBlock Canvas.Left="28" Canvas.Top="468" Text="set your connections here" FontFamily="{StaticResource ScriptFont}" FontSize="22" Foreground="{StaticResource GreenBrush}" />
                    <TextBlock Canvas.Left="58" Canvas.Top="505" Text="↙" FontFamily="Segoe UI Symbol" FontSize="88" Foreground="{StaticResource GreenBrush}" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="-16" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Canvas.Left="28" Canvas.Top="648" Text="/connections" FontFamily="{StaticResource PixelFont}" FontSize="24" Foreground="#FFFFFF" />
                    <TextBlock Canvas.Left="298" Canvas.Top="648" Text="/settings" FontFamily="{StaticResource PixelFont}" FontSize="24" Foreground="#FFFFFF" />
                </Canvas>
            </Border>
            <Button HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,22" Style="{StaticResource ScaleTextButton}" Foreground="{StaticResource GreenBrush}" Click="LetMeIn_Click">
                <TextBlock Text="let me in!" FontSize="30" />
            </Button>
        </Grid>

        <Grid x:Name="MainScreen" Background="#000000" Visibility="Collapsed">
            <Border Background="#000000" CornerRadius="0,0,92,92" Height="724" VerticalAlignment="Top">
                <Canvas>
                    <TextBlock Canvas.Left="0" Canvas.Top="-8" Width="500" Text="LOKI PROXY" TextAlignment="Center" FontFamily="{StaticResource DecorFont}" FontSize="55.65" Foreground="{StaticResource GreenBrush}" />
                    <TextBlock x:Name="ClockText" Canvas.Left="15" Canvas.Top="64" Text="09 may 17:41:25" FontFamily="{StaticResource PixelFont}" FontSize="22" Foreground="#FFFFFF" />
                    <Grid x:Name="MainProgressRing" Canvas.Left="130" Canvas.Top="275" Width="240" Height="240" Visibility="Collapsed" IsHitTestVisible="False">
                        <Canvas x:Name="MainProgressDots" Width="240" Height="240" />
                    </Grid>
                    <Button x:Name="MainConnectButton" Canvas.Left="140" Canvas.Top="330" Width="220" Height="130"
                            Style="{StaticResource MainCenterButton}"
                            Click="ConnectButton_Click"
                            MouseEnter="MainConnectButton_MouseEnter"
                            MouseLeave="MainConnectButton_MouseLeave"
                            PreviewMouseLeftButtonDown="MainConnectButton_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="MainConnectButton_PreviewMouseLeftButtonUp">
                        <StackPanel Width="220">
                            <TextBlock x:Name="MainStateText" Text="OFF" FontFamily="{StaticResource PixelFont}" FontSize="52" TextAlignment="Center" Foreground="#FFFFFF" />
                            <TextBlock x:Name="MainLine1Text" Text="Hey!" FontFamily="{StaticResource PixelFont}" FontSize="19" TextAlignment="Center" Foreground="#FFFFFF" />
                            <TextBlock x:Name="MainLine2Text" Text="Push on me!" FontFamily="{StaticResource PixelFont}" FontSize="19" TextAlignment="Center" Foreground="#FFFFFF" />
                        </StackPanel>
                    </Button>
                </Canvas>
            </Border>
            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="15,0,15,30"
                    Width="470" Height="50"
                    ClipToBounds="False">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource MainNavSegmentButton}" Click="Connections_Click" HorizontalContentAlignment="Left" BorderThickness="1.5,1.5,0,1.5" RenderTransformOrigin="1,0.5">
                        <TextBlock Text="connections" Style="{StaticResource MainNavSegmentText}" Margin="18,0,0,0" />
                    </Button>
                    <Button Grid.Column="1" Style="{StaticResource MainNavSegmentButton}" Click="Settings_Click" HorizontalContentAlignment="Right" BorderThickness="0,1.5,1.5,1.5" RenderTransformOrigin="0,0.5">
                        <TextBlock Text="settings" Style="{StaticResource MainNavSegmentText}" Margin="0,0,18,0" />
                    </Button>
                    <Border Grid.ColumnSpan="2"
                            HorizontalAlignment="Center"
                            Width="1.5"
                            Background="{StaticResource WhiteBrush}"
                            Panel.ZIndex="10"
                            IsHitTestVisible="False" />
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="ConnectionsScreen" Background="#000000" Visibility="Collapsed">
            <Canvas>
                <TextBlock Canvas.Left="15" Canvas.Top="-8" Width="470" Text="CONNECTIONS" TextAlignment="Center" FontFamily="{StaticResource DecorFont}" FontSize="48.35" Foreground="{StaticResource GreenBrush}" />
                <Button Canvas.Left="15" Canvas.Top="54" Style="{StaticResource PixelTextButton}" Click="MainMenu_Click">
                    <TextBlock Text="&lt;- back to the main menu" FontSize="24" />
                </Button>
                <ListBox x:Name="ProfilesList" Canvas.Left="32" Canvas.Top="150" Width="438" Height="500"
                          Background="Transparent" BorderThickness="0" Foreground="#FFFFFF"
                          FontFamily="{StaticResource PixelFont}" FontSize="24"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="ProfilesList_SelectionChanged"
                         PreviewMouseRightButtonDown="ProfilesList_PreviewMouseRightButtonDown"
                         ContextMenu="{x:Null}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Height" Value="50" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                            <Setter Property="ContextMenu" Value="{x:Null}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Top" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" LineHeight="28" Height="28">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                                <Setter Property="TextDecorations" Value="Underline" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Canvas.Right="25" Canvas.Top="712" Style="{StaticResource PixelTextButton}" Click="AddConnection_Click">
                    <TextBlock Text="add connection -&gt;" FontSize="24" />
                </Button>
            </Canvas>
        </Grid>

        <Grid x:Name="AddConnectionScreen" Background="#FFFFFF" Visibility="Collapsed">
            <Canvas>
                <TextBlock Canvas.Left="0" Canvas.Top="156" Width="500" Text="copy connection link first" TextAlignment="Center" FontFamily="{StaticResource PixelFont}" FontSize="24" Foreground="#000000" />
                <Button Canvas.Left="32" Canvas.Top="270" Width="430" Style="{StaticResource DarkPixelButton}" Click="ImportClipboard_Click">
                    <TextBlock Text="1. Import link from clipboard" FontSize="27" />
                </Button>
                <Button Canvas.Left="32" Canvas.Top="334" Width="440" Style="{StaticResource DarkPixelButton}" Click="ImportSubscription_Click">
                    <TextBlock Text="2. Import via subscription link" FontSize="27" />
                </Button>
                <Button Canvas.Left="32" Canvas.Top="729" Style="{StaticResource DarkPixelButton}" Click="Connections_Click">
                    <TextBlock Text="&lt;- back to connections" FontSize="21" />
                </Button>
            </Canvas>
        </Grid>

        <Grid x:Name="SettingsScreen" Background="#000000" Visibility="Collapsed">
            <Canvas>
                <TextBlock Canvas.Left="15" Canvas.Top="-8" Text="SETTINGS" FontFamily="{StaticResource DecorFont}" FontSize="54" Foreground="{StaticResource GreenBrush}" />
                <Button Canvas.Left="15" Canvas.Top="54" Style="{StaticResource PixelTextButton}" Click="MainMenu_Click">
                    <TextBlock Text="&lt;- back to the main menu" FontSize="24" />
                </Button>
                <Button Canvas.Left="32" Canvas.Top="150" Style="{StaticResource PixelTextButton}" Click="RoutingSettings_Click">
                    <TextBlock Text="1. Routing settings" FontSize="24" />
                </Button>
                <Button Canvas.Left="32" Canvas.Top="200" Style="{StaticResource PixelTextButton}" Click="LogsToggle_Click">
                    <TextBlock x:Name="LogsToggleText" Text="2. Logs: collect/send logs" FontSize="24" />
                </Button>
                <Button Canvas.Left="32" Canvas.Top="250" Style="{StaticResource PixelTextButton}" Click="AutoUpdateToggle_Click">
                    <TextBlock x:Name="AutoUpdateToggleText" Text="3. Auto updates enabled" FontSize="24" />
                </Button>
                <Button Canvas.Left="32" Canvas.Top="300" Style="{StaticResource PixelTextButton}" Click="RequestUpdate_Click">
                    <TextBlock Text="4. Request update" FontSize="24" />
                </Button>
                <Button Canvas.Left="32" Canvas.Top="350" Style="{StaticResource PixelTextButton}" Click="ShowFirstLaunchGuide_Click">
                    <TextBlock Text="5. Open first launch guide" FontSize="24" />
                </Button>
                <Button Canvas.Left="32" Canvas.Top="400" Style="{StaticResource PixelTextButton}" Click="DeleteApp_Click">
                    <TextBlock Text="6. Delete application" FontSize="24" />
                </Button>
                <TextBlock x:Name="SettingsMessageText" Canvas.Left="32" Canvas.Top="480" Width="430" TextWrapping="Wrap"
                           FontFamily="{StaticResource PixelFont}" FontSize="18" Foreground="{StaticResource GreenBrush}" />
                <TextBlock x:Name="ClientVersionText" Canvas.Left="32" Canvas.Top="744" Width="430"
                           FontFamily="{StaticResource PixelFont}" FontSize="14" Foreground="#777777" TextAlignment="Right" />
            </Canvas>
        </Grid>

        <Grid x:Name="RoutingSettingsScreen" Background="#000000" Visibility="Collapsed">
            <Canvas>
                <TextBlock Canvas.Left="15" Canvas.Top="-8" Text="ROUTING" FontFamily="{StaticResource DecorFont}" FontSize="54" Foreground="{StaticResource GreenBrush}" />
                <Button Canvas.Left="15" Canvas.Top="54" Style="{StaticResource PixelTextButton}" Click="Settings_Click">
