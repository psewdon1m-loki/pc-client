        <Grid x:Name="DeleteAppConfirmOverlay" Visibility="Collapsed" Background="#99000000" Panel.ZIndex="50">
            <Border Width="370" Background="#000000" BorderBrush="#FFFFFF" BorderThickness="1" Padding="16,12"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Delete Loki Proxy VPN?" FontFamily="{StaticResource PixelFont}" FontSize="22"
                               Foreground="{StaticResource RedBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />
                    <TextBlock Text="Active connection will be stopped. The app, shortcuts, settings and local data will be removed from this system."
                               FontFamily="{StaticResource PixelFont}" FontSize="17" Foreground="#FFFFFF"
                               TextWrapping="Wrap" Margin="0,0,0,14" />
                    <Button Style="{StaticResource PixelTextButton}" FontSize="20" HorizontalContentAlignment="Left"
                            Foreground="{StaticResource RedBrush}" Click="ConfirmDeleteApp_Click">1. Delete application</Button>
                    <Button Style="{StaticResource PixelTextButton}" FontSize="20" HorizontalContentAlignment="Left"
                            Click="CancelDeleteApp_Click">2. Cancel</Button>
                </StackPanel>
            </Border>
        </Grid>

        <Popup x:Name="ConnectionContextPopup" Placement="MousePoint" StaysOpen="False" AllowsTransparency="False">
            <Border Width="240" Background="#000000" BorderBrush="#FFFFFF" BorderThickness="1" Padding="16,10">
                <StackPanel>
                    <Button Style="{StaticResource PixelTextButton}" FontSize="18" HorizontalContentAlignment="Left" Click="SetActiveProfile_Click">1. Set as active</Button>
                    <Button Style="{StaticResource PixelTextButton}" FontSize="18" HorizontalContentAlignment="Left" Click="ClearActiveProfile_Click">2. Clear as active</Button>
                    <Button Style="{StaticResource PixelTextButton}" FontSize="18" HorizontalContentAlignment="Left" Click="DeleteProfile_Click">3. Delete connection</Button>
                </StackPanel>
            </Border>
        </Popup>
        </Grid>
    </Grid>
</Window>
