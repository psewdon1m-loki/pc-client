                <TextBlock Canvas.Left="32" Canvas.Top="245" Text="Rule List" FontFamily="{StaticResource PixelFont}" FontSize="25" Foreground="{StaticResource GreenBrush}" />
                <Button Canvas.Left="42" Canvas.Top="300" Width="430" Style="{StaticResource PixelTextButton}" Click="RuleDetails_Click">
