                    <TextBlock Text="&lt;- back to rules" FontSize="24" />
                </Button>
                <TextBlock Canvas.Left="28" Canvas.Top="128" Text="Remarks" FontFamily="{StaticResource PixelFont}" FontSize="19" Foreground="#FFFFFF" />
                <TextBox Canvas.Left="175" Canvas.Top="122" Width="285" Text="Ozon напрямую" Style="{StaticResource RoutingField}" />
                <TextBlock Canvas.Left="28" Canvas.Top="174" Text="Rule Type" FontFamily="{StaticResource PixelFont}" FontSize="19" Foreground="#FFFFFF" />
                <TextBox Canvas.Left="175" Canvas.Top="168" Width="285" Text="domain" Style="{StaticResource RoutingField}" />
                <TextBlock Canvas.Left="28" Canvas.Top="220" Text="outboundTag" FontFamily="{StaticResource PixelFont}" FontSize="19" Foreground="#FFFFFF" />
                <TextBox Canvas.Left="175" Canvas.Top="214" Width="285" Text="direct" Style="{StaticResource RoutingField}" />
                <Border Canvas.Left="28" Canvas.Top="285" Width="432" Height="150" BorderBrush="{StaticResource GreenBrush}" BorderThickness="1">
                    <Grid>
                        <TextBlock Text="Domain" FontFamily="{StaticResource PixelFont}" FontSize="18" Foreground="#000000" Background="{StaticResource GreenBrush}" Padding="8,4" />
