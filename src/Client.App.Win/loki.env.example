# Copy this file to loki.env next to Client.App.Win.exe or to %LOCALAPPDATA%\LokiClient\loki.env.
# Use the public telemetry hostname in production so TLS SNI, certificate name, and routing host match.
LOKI_TELEMETRY_ENDPOINT=http://127.0.0.1:18080
LOKI_TELEMETRY_SNI=
LOKI_TELEMETRY_UPLOAD_INTERVAL_MINUTES=60
LOKI_TELEMETRY_COMMAND_POLL_SECONDS=300

# GitHub Releases update manifest, for example:
# https://github.com/<org>/<repo>/releases/latest/download/manifest.json
LOKI_UPDATE_MANIFEST_URL=
LOKI_UPDATE_CHANNEL=stable
LOKI_UPDATE_CHECK_INTERVAL_MINUTES=360

# Optional RSA public key for manifest signature verification.
# Store newlines as \n when keeping the key on one env line.
LOKI_UPDATE_PUBLIC_KEY_PEM=
