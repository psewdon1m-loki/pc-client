<Window x:Class="Client.App.Win.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить профиль" Height="260" Width="560" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Вставьте vless:// ссылку или subscription URL" FontSize="16" FontWeight="SemiBold" />
        <TextBox x:Name="InputBox" Grid.Row="1" Margin="0,14,0,14" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Width="100" Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="Добавить" Width="120" Background="#1B7F5F" Foreground="White" Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>

